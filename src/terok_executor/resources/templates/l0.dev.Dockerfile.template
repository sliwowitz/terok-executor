# syntax=docker/dockerfile:1
#
# L0 — base dev image shared by every terok project.
#
# Identical image content under both supported OCI runtimes (``crun``
# and ``krun``).  The vsock-bound sshd machinery added below is
# **dormant under crun** (no ``vhost-vsock`` device in the namespace ⇒
# ``sshd.socket`` has nothing to bind to) and **active under krun**
# (the microVM exposes vsock, the socket activates, the host can
# reach in via ``ssh -o ProxyCommand=socat -…``).  One image, one
# build, two runtimes.
#
# The trust file ``/etc/ssh/authorized_keys.d/terok`` ships **empty**:
# the live host pubkey is bind-mounted in at task launch by terok,
# so the image never carries a per-installation secret and stays
# cacheable across hosts.
#
# Family branching (apt vs dnf) follows the ``family`` Jinja variable;
# systemd socket/service names differ by family
# ({{ ssh_socket_name }} / {{ ssh_service_name }} resolve to
# ``ssh.socket``/``ssh.service`` on deb, ``sshd.socket``/``sshd.service``
# on rpm).

ARG BASE_IMAGE={{ BASE_IMAGE }}
FROM ${BASE_IMAGE}

ENV {% if family == "deb" %}DEBIAN_FRONTEND=noninteractive \
    {% endif %}REPO_ROOT="/workspace" \
    GIT_RESET_MODE="none" \
    LANG="en_US.UTF-8" \
    LC_ALL="en_US.UTF-8" \
    LANGUAGE="en_US:en" \
    USER="dev"

# Basic dev tooling common to all projects.  ``tzdata`` is explicit on
# both families so the runtime ``TZ`` env var — set from the host's
# timezone — can resolve against ``/usr/share/zoneinfo``.
# ``openssh-server`` + ``socat`` + ``systemd`` are included so the
# krun-mode sshd-on-vsock path works; under crun they're inert.
{% if family == "deb" -%}
RUN apt-get update && apt-get install -y --no-install-recommends \
      ca-certificates curl gnupg git locales openssh-client openssh-server \
      socat sudo systemd-sysv ripgrep vim tmux tzdata \
    && rm -rf /var/lib/apt/lists/*

# Ensure en_US.UTF-8 exists so bash and agent-spawned shells can always set LC_ALL safely.
RUN set -eux; \
    sed -i 's/^# *en_US.UTF-8 UTF-8/en_US.UTF-8 UTF-8/' /etc/locale.gen; \
    grep -q '^en_US.UTF-8 UTF-8' /etc/locale.gen || echo 'en_US.UTF-8 UTF-8' >> /etc/locale.gen; \
    locale-gen en_US.UTF-8
{%- else -%}
# glibc-langpack-en provides en_US.UTF-8 directly — no locale-gen step needed.
RUN dnf install -y --setopt=install_weak_deps=False \
      ca-certificates curl gnupg2 git glibc-langpack-en openssh-clients openssh-server \
      socat sudo systemd ripgrep vim tmux tzdata \
    && dnf clean all
{%- endif %}

RUN set -eux; \
    uid_owner="$(getent passwd 1000 | cut -d: -f1 || true)"; \
    if [ -n "$uid_owner" ] && [ "$uid_owner" != "dev" ]; then \
      if getent group "$uid_owner" >/dev/null; then groupmod -n dev "$uid_owner" || true; fi; \
      usermod -l dev "$uid_owner"; \
      usermod -d /home/dev -m dev; \
      # usermod -l / groupmod -n don't touch /etc/sub{u,g}id; rewrite \
      # those entries so pre-configured rootless ranges (e.g. the podman \
      # image's `podman:100000:65536`) keep working under the new name. \
      for f in /etc/subuid /etc/subgid; do \
        [ -f "$f" ] && sed -i "s/^${uid_owner}:/dev:/" "$f"; \
      done; \
    fi; \
    if ! getent group dev >/dev/null; then \
      groupadd dev; \
    fi; \
    if ! id -u dev >/dev/null 2>&1; then \
      useradd -m -u 1000 -g dev -s /bin/bash dev; \
    fi; \
    if [ "$(id -u dev)" != "1000" ]; then usermod -u 1000 dev; fi; \
    echo 'dev ALL=(ALL) NOPASSWD: ALL' > /etc/sudoers.d/dev; \
    chmod 0440 /etc/sudoers.d/dev; \
    visudo -cf /etc/sudoers.d/dev; \
{% if family == "rpm" %}    if [ "$(stat -c '%a' /etc/shadow)" = "0" ]; then \
        printf '%s\n' '#%PAM-1.0' \
            'auth sufficient pam_succeed_if.so ruser = dev' \
            'auth include system-auth' \
            'account sufficient pam_succeed_if.so ruser = dev' \
            'account include system-auth' \
            'password include system-auth' \
            'session include system-auth' \
            > /etc/pam.d/sudo; \
    fi; \
{% endif %}    mkdir -p /workspace /home/dev/.ssh; \
    chown -R dev:dev /home/dev /workspace; \
    chmod 700 /home/dev/.ssh; \
    chmod 0777 /workspace

# ── krun: sshd-on-vsock (dormant under crun) ────────────────────────
#
# Pubkey-only sshd hardened down to the single ``dev`` account, no
# forwarding of any kind, trust file at the system-wide
# ``authorized_keys.d/terok`` slot so the in-guest dev user cannot
# edit the trust file from inside.
#
# The trust file ships **empty** — the live host pubkey is
# bind-mounted in at task launch by terok (so the L0 image never
# carries a per-installation secret).  Under crun the vsock socket
# never activates ⇒ sshd never reads it ⇒ the empty file is
# harmless.  Under krun the socket binds vsock::22 ⇒ sshd reads the
# bind-mounted file ⇒ the host can reach in via SSH-over-vsock.
#
# Distro's stock TCP ``{{ ssh_service_name }}`` is **masked**: even
# if a package's post-install enables it, systemd refuses to start
# it.  Only the socket-activated path lives.
RUN install -d -m 0755 /etc/ssh/sshd_config.d \
    && install -d -m 0755 /etc/ssh/authorized_keys.d \
    && printf '%s\n' \
        '# terok krun guest hardening — dormant under crun, active under krun.' \
        'PermitRootLogin no' \
        'PasswordAuthentication no' \
        'PermitEmptyPasswords no' \
        'KbdInteractiveAuthentication no' \
        'PubkeyAuthentication yes' \
        'AllowUsers dev' \
        'AllowAgentForwarding no' \
        'AllowTcpForwarding no' \
        'X11Forwarding no' \
        'PermitTunnel no' \
        'GatewayPorts no' \
        'AuthorizedKeysFile /etc/ssh/authorized_keys.d/terok' \
        > /etc/ssh/sshd_config.d/00-terok-krun.conf \
    && : > /etc/ssh/authorized_keys.d/terok \
    && chmod 0644 /etc/ssh/authorized_keys.d/terok \
    && install -d -m 0755 /etc/systemd/system/{{ ssh_socket_name }}.d \
    && printf '%s\n' \
        '[Socket]' \
        'ListenStream=' \
        'ListenStream=vsock::22' \
        > /etc/systemd/system/{{ ssh_socket_name }}.d/vsock.conf \
    && systemctl enable {{ ssh_socket_name }} \
    && systemctl mask {{ ssh_service_name }}

WORKDIR /workspace

COPY scripts/init-ssh-and-repo.sh /usr/local/bin/init-ssh-and-repo.sh
COPY scripts/ssh-agent-bridge.sh /usr/local/bin/ssh-agent-bridge.sh
COPY scripts/ensure-bridges.sh /usr/local/bin/ensure-bridges.sh
RUN chmod +x /usr/local/bin/init-ssh-and-repo.sh /usr/local/bin/ssh-agent-bridge.sh /usr/local/bin/ensure-bridges.sh

# tmux config for persistent login sessions (prefix ^a, green status bar)
COPY tmux/container-tmux.conf /etc/tmux.conf

ENV HOME=/home/dev
USER dev
CMD ["init-ssh-and-repo.sh"]
